  blankMonitor: {fileID: 1087477759}
  bootingTV: {fileID: 9726673}
  beritaKonteks: {fileID: 1036200132}
  beritaKonteksFullscreen: {fileID: 1967303111}
  tvEffectMaterial: {fileID: 2100000, guid: 7b298ab79aaf3bb47878e218b7b5aa60, type: 2}
  bubbleNamePanel: {fileID: 101040296}
  panelKoran: {fileID: 1588518896}
  panelKasur: {fileID: 469754643}
  daftarGambarKoran:
  - {fileID: 193584069}
  - {fileID: 201554810}
  - {fileID: 1514784914}
  - {fileID: 725415036}
  - {fileID: 1781380115}
  panelBackgroundDialog: {fileID: 957392510}
  panelNamaKarakter: {fileID: 101040296}
  loadingSlider: {fileID: 1247535616}
  textNamaKarakter: {fileID: 211173253}
  textIsiDialog: {fileID: 1029806812}
  dialogAwal:
  - namaKarakter: ???
    teksDialog: Hahhhh... akhirnya sampai rumah juga.
  - namaKarakter: ???
    teksDialog: Gila, hari ini capeknya bukan main. Punggung rasanya kayak mau patah
      duduk seharian.
  - namaKarakter: ???
    teksDialog: Oke... tas taruh sini dulu. Mandi? Nanti aja deh, airnya pasti dingin
      banget. Mending rebahan dulu sebentar.
  - namaKarakter: ???
    teksDialog: Nah, ini dia surga dunia... empuk banget ini sofa. Tolong jangan
      ada yang hubungin gue dulu malam ini.
  - namaKarakter: ???
    teksDialog: Mana remote TVnya ya? Perasaan tadi pagi gue taruh dikasur...
  - namaKarakter: ???
    teksDialog: Wah berantakan banget
  - namaKarakter: ???
    teksDialog: Remote TVnya mungkin didalam susunan pakaian yang berantakan ini
  - namaKarakter: ???
    teksDialog: 'cari dulu deh '
  - namaKarakter: ???
    teksDialog: 'Coba kita lihat hari ini ada kejadian penting apa. '
  - namaKarakter: ???
    teksDialog: Tadi di kantor pada heboh ngomongin sesuatu
  - namaKarakter: ???
    teksDialog: Gue malah sibuk sendiri nggak sempat buka portal berita.
  dialogBerita:
  - namaKarakter: 'Pembawa Acara '
    teksDialog: Selamat Malam, Kembali lagi Bersama saya Monika
  - namaKarakter: Monika
    teksDialog: 'Pemirsa, berita terkini: gelombang migrasi pemuda desa kembali meningkat.'
  - namaKarakter: Monika
    teksDialog: Banyak anak muda memilih meninggalkan kampung halaman
  - namaKarakter: 'Monika '
    teksDialog: demi mencari pekerjaan di kota
  - namaKarakter: Monika
    teksDialog: meninggalkan lahan dan rumah-rumah kosong di belakang mereka.
  - namaKarakter: Monika
    teksDialog: Kondisi ini menimbulkan kekhawatiran akan masa depan desa,
  - namaKarakter: Monika
    teksDialog: 'terutama pada sektor pertanian dan pendidikan '
  - namaKarakter: Monika
    teksDialog: yang kini kekurangan generasi penerus..
  dialogKedua:
  - namaKarakter: ???
    teksDialog: Wah sampe masuk berita TV gini masalahnya
  - namaKarakter: ???
    teksDialog: 'Bahkan dikoran pagi pun banyak yang memberitakan hal tersebut '
  durasiFadeBlack: 1.5
  jedaSebelumDialog: 3
  jedaSetelahDialogAwal: 2
  durasiBootingTV: 5
  durasiFadeOut: 1
  jedaBacaBerita: 3
  durasiTransisiTeks: 0.3
  sedangMencariBarang: 0
